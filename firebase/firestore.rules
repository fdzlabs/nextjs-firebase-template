rules_version = '2';

// Example Firestore security rules for this template.
// Matches the client profile helpers in `src/lib/user-profile.ts`
// (collection: `users`, document id = auth uid).
//
// Deploy:
//   firebase deploy --only firestore:rules
// Or paste into Firebase Console → Firestore → Rules.

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Allowed profile shape from `src/lib/user-profile.ts` (no arbitrary extras).
    function isValidProfileKeys() {
      let data = request.resource.data;
      return data.keys().hasOnly([
        'uid',
        'displayName',
        'bio',
        'photoURL',
        'email',
        'createdAt',
        'updatedAt',
      ])
        && data.keys().hasAll(['uid', 'displayName', 'bio'])
        && data.uid is string
        && data.displayName is string
        && data.displayName.size() <= 100
        && data.bio is string
        && data.bio.size() <= 500
        && (!('photoURL' in data) || data.photoURL == null || data.photoURL is string)
        && (!('email' in data) || data.email == null || data.email is string)
        && (!('createdAt' in data) || data.createdAt == null || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp);
    }

    // User-owned profile documents
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && isValidProfileKeys();
      allow update: if isOwner(userId)
        && request.resource.data.uid == userId
        && isValidProfileKeys();
      allow delete: if isOwner(userId);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
